# Cloud sync + daily-drill leaderboard (FEATURE-04). Entirely optional.
#
# SDPD runs fully offline/anonymous with no account features when these are
# unset — there is no wall, no crash, and no network call. Copy this file to
# `.env.local` and fill in real values only if you want to turn sync and the
# leaderboard on for your own Supabase project.
#
# See the "Cloud Sync & Leaderboard Setup" section of README.md for the full
# dashboard walkthrough, and supabase/migrations/0001_accounts_leaderboard.sql
# for the schema to run.

# Project Settings → API → Project URL
VITE_SUPABASE_URL=

# Project Settings → API → Project API keys → anon / public
# This key is safe to ship to the client — Row Level Security (already
# defined in the migration) is the actual access-control boundary. Never put
# the service_role key here or anywhere in client code.
VITE_SUPABASE_ANON_KEY=
